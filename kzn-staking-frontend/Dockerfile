FROM node:20-alpine

WORKDIR /app

ARG NEXT_PUBLIC_SEPOLIA_RPC_URL
ARG NEXT_PUBLIC_KZN_TOKEN_ADDRESS
ARG NEXT_PUBLIC_KZN_STAKING_ADDRESS

ENV NEXT_PUBLIC_SEPOLIA_RPC_URL=${NEXT_PUBLIC_SEPOLIA_RPC_URL}
ENV NEXT_PUBLIC_KZN_TOKEN_ADDRESS=${NEXT_PUBLIC_KZN_TOKEN_ADDRESS}
ENV NEXT_PUBLIC_KZN_STAKING_ADDRESS=${NEXT_PUBLIC_KZN_STAKING_ADDRESS}

COPY package*.json ./
RUN npm ci

COPY . .

RUN npm run build

EXPOSE 3000

CMD ["npm", "run", "start", "--", "--hostname", "0.0.0.0", "--port", "3000"]
